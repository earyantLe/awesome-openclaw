# =============================================================================
# Awesome OpenClaw - 自动化更新配置文件
# =============================================================================
# 说明：复制此文件为 update.config 并填写实际配置值
# 安全提示：不要将此文件提交到 Git 仓库（已加入 .gitignore）
# =============================================================================

# -----------------------------------------------------------------------------
# GitHub API 配置
# -----------------------------------------------------------------------------
# 单 Token 模式（简单场景）
# export GITHUB_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxx"

# 多 Token 轮询模式（高并发场景）
# 将多个 Token 写入文件，每行一个
export GITHUB_TOKEN_FILE="${HOME}/.config/awesome-openclaw/github-tokens.txt"

# -----------------------------------------------------------------------------
# API 限流配置
# -----------------------------------------------------------------------------
# 请求间隔（秒）- 避免触发二次限流
export RATE_LIMIT_DELAY=2

# 最大重试次数
export MAX_RETRIES=3

# 重试延迟（秒）
export RETRY_DELAY=5

# -----------------------------------------------------------------------------
# 并发控制
# -----------------------------------------------------------------------------
# 最大并发请求数（建议 3-5，避免触发 GitHub 速率限制）
export MAX_CONCURRENT=3

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
# 日志目录
export LOG_DIR="/var/log/awesome-openclaw"

# 日志保留天数
export LOG_RETENTION_DAYS=7

# -----------------------------------------------------------------------------
# 监控告警配置
# -----------------------------------------------------------------------------
# Telegram 通知（可选）
# export TELEGRAM_BOT_TOKEN="1234567890:ABCdefGHIjklMNOpqrsTUVwxyz"
# export TELEGRAM_CHAT_ID="-1001234567890"

# 飞书 webhook 通知（可选）
# export FEISHU_WEBHOOK="https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx"

# -----------------------------------------------------------------------------
# 执行计划
# -----------------------------------------------------------------------------
# Cron 表达式：每 2 小时执行一次（避开整点，分散负载）
# 分钟 小时 日 月 周
#   15  */2  *  *  *
CRON_SCHEDULE="15 */2 * * *"

# -----------------------------------------------------------------------------
# 其他配置
# -----------------------------------------------------------------------------
# 是否启用详细日志（true/false）
export VERBOSE_LOG=false

# 是否启用调试模式（true/false）
export DEBUG_MODE=false
